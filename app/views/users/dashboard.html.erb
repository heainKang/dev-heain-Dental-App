<% content_for :title, "대시보드 - DentalNow" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 환영 메시지 -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 mb-1">
            안녕하세요, <%= current_user.name %>님! 👋
          </h1>
          <p class="text-gray-600">
            오늘도 좋은 기회를 찾아보세요
          </p>
        </div>
        <div class="hidden sm:block w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center">
          <span class="text-2xl font-bold text-blue-600">
            <%= current_user.name&.first&.upcase || 'U' %>
          </span>
        </div>
      </div>
    </div>

    <!-- 통계 카드들 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium mb-1">총 지원</p>
            <p class="text-3xl font-bold text-gray-900"><%= @stats[:total_applications] %></p>
          </div>
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium mb-1">대기중</p>
            <p class="text-3xl font-bold text-orange-900"><%= @stats[:pending_applications] %></p>
          </div>
          <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-medium mb-1">승인됨</p>
            <p class="text-3xl font-bold text-green-900"><%= @stats[:accepted_applications] %></p>
          </div>
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- 최근 지원 현황 -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-900">최근 지원 현황</h2>
            <%= link_to "전체 보기", "#", class: "text-blue-600 hover:text-blue-700 font-medium text-sm" %>
          </div>
          
          <% if @recent_applications.any? %>
            <div class="space-y-4">
              <% @recent_applications.each do |application| %>
                <div class="border border-gray-200 rounded-lg p-4 hover:border-blue-300 transition-colors">
                  <div class="flex justify-between items-start mb-2">
                    <div class="flex-1">
                      <h3 class="font-semibold text-gray-900 mb-1">
                        <%= link_to application.job.title, job_path(application.job), 
                            class: "hover:text-blue-600 transition-colors" %>
                      </h3>
                                             <p class="text-sm text-gray-600 mb-2">
                         <%= application.job.hospital.name %> • <%= application.job.hospital.address&.split(',')&.first || '위치 정보 없음' %>
                       </p>
                      <p class="text-xs text-gray-500">
                        <%= time_ago_in_words(application.created_at) %> 전 지원
                      </p>
                    </div>
                    <span class="bg-orange-100 text-orange-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                      <%= application.status.humanize %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-8">
              <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 mb-2">아직 지원한 공고가 없습니다</h3>
              <p class="text-gray-600 mb-4">관심 있는 구인공고에 지원해보세요!</p>
              <%= link_to "구인공고 둘러보기", jobs_path, 
                  class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 빠른 액션 및 추천 -->
      <div class="space-y-6">
        <!-- 빠른 액션 -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4">빠른 액션</h2>
          <div class="space-y-3">
            <%= link_to jobs_path, 
                class: "w-full flex items-center space-x-3 p-3 border border-gray-200 rounded-lg hover:border-blue-300 hover:bg-blue-50 transition-colors group" do %>
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">구인공고 찾기</p>
                <p class="text-xs text-gray-600">새로운 기회를 찾아보세요</p>
              </div>
            <% end %>
            
            <% if current_user.jobseeker? %>
              <% if current_user.profile&.persisted? %>
                <%= link_to profile_path(current_user.profile), 
                    class: "w-full flex items-center space-x-3 p-3 border border-gray-200 rounded-lg hover:border-green-300 hover:bg-green-50 transition-colors group" do %>
                  <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center group-hover:bg-green-200 transition-colors">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">프로필 관리</p>
                    <p class="text-xs text-gray-600">내 정보를 업데이트하세요</p>
                  </div>
                <% end %>
              <% else %>
                <%= link_to new_profile_path, 
                    class: "w-full flex items-center space-x-3 p-3 border border-orange-200 rounded-lg hover:border-orange-300 hover:bg-orange-50 transition-colors group" do %>
                  <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center group-hover:bg-orange-200 transition-colors">
                    <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">프로필 만들기</p>
                    <p class="text-xs text-gray-600">프로필을 완성하세요</p>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <%= link_to hospitals_path, 
                  class: "w-full flex items-center space-x-3 p-3 border border-gray-200 rounded-lg hover:border-purple-300 hover:bg-purple-50 transition-colors group" do %>
                <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                  <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">병원 관리</p>
                  <p class="text-xs text-gray-600">내 병원 정보를 관리하세요</p>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- 추천 구인공고 -->
        <% if @recommended_jobs.any? %>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">추천 구인공고</h2>
            <div class="space-y-3">
              <% @recommended_jobs.limit(3).each do |job| %>
                <div class="border border-gray-200 rounded-lg p-3 hover:border-blue-300 transition-colors">
                  <h3 class="font-medium text-gray-900 text-sm mb-1">
                    <%= link_to job.title, job_path(job), class: "hover:text-blue-600 transition-colors" %>
                  </h3>
                                     <p class="text-xs text-gray-600 mb-2">
                     <%= job.hospital.name %> • <%= job.hospital.address&.split(',')&.first || '위치 정보 없음' %>
                   </p>
                                     <div class="flex justify-between items-center">
                     <span class="text-sm font-semibold text-blue-600">
                       <%= number_to_currency(job.hourly_rate, unit: "", precision: 0) %>원
                     </span>
                     <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">
                       <%= job.status.humanize %>
                     </span>
                   </div>
                </div>
              <% end %>
            </div>
            <div class="mt-4">
              <%= link_to "더 많은 추천 보기", jobs_path, 
                  class: "text-blue-600 hover:text-blue-700 font-medium text-sm" %>
            </div>
          </div>
        <% end %>

        <!-- 알림 설정 -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-2">알림 설정</h2>
          <p class="text-sm text-gray-600 mb-4">새로운 구인공고 알림을 받아보세요</p>
          <button class="mobile-btn mobile-btn-primary mobile-btn-full mobile-btn-sm">
            알림 설정하기
          </button>
        </div>
      </div>
    </div>
  </div>
</div>