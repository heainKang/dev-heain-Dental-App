<% content_for :title, "로그인 - DentalNow" %>

<!-- Modern Login Page -->
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-6">
    <!-- Header -->
    <div class="text-center">
      <div class="mx-auto h-12 w-12 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-xl flex items-center justify-center mb-6 shadow-md">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h1 class="text-2xl font-bold text-slate-900 mb-2">
        다시 만나서 반가워요
      </h1>
      <p class="text-slate-600 text-sm">
        DentalNow에 로그인하여 시작하세요
      </p>
    </div>

    <!-- Login Form -->
    <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-slate-200/60 p-6">
      <!-- Error Messages -->
      <% if alert %>
        <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-3">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-4 w-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2">
              <p class="text-sm font-medium text-red-800"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>
      
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true, html: { class: "space-y-4" }) do |f| %>
        
        <!-- Email Field -->
        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-medium text-slate-700 mb-2" %>
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email",
              placeholder: "example@dentalnow.com",
              class: "block w-full px-3 py-2.5 border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-sm bg-white/50" %>
        </div>

        <!-- Password Field -->
        <div>
          <%= f.label :password, "비밀번호", class: "block text-sm font-medium text-slate-700 mb-2" %>
          <%= f.password_field :password, 
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "block w-full px-3 py-2.5 border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-sm bg-white/50" %>
        </div>

        <!-- Remember Me & Forgot Password -->
        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center">
              <%= f.check_box :remember_me, 
                  class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-slate-300 rounded" %>
              <span class="ml-2 text-sm text-slate-600">로그인 상태 유지</span>
            </label>
          <% end %>
          
          <% if devise_mapping.recoverable? %>
            <%= link_to "비밀번호 찾기", new_password_path(resource_name), 
                class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium" %>
          <% end %>
        </div>

        <!-- Login Button -->
        <div>
          <%= f.submit "로그인", 
              class: "w-full py-2.5 px-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-sm font-medium rounded-lg hover:from-indigo-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-all duration-200 shadow-sm hover:shadow-md" %>
        </div>

        <!-- Sign Up Link -->
        <div class="text-center pt-2">
          <p class="text-sm text-slate-600">
            계정이 없으신가요?
            <%= link_to "가입하기", new_registration_path(resource_name), 
                class: "font-medium text-indigo-600 hover:text-indigo-700 ml-1" %>
          </p>
        </div>
      <% end %>
    </div>

    <!-- Footer -->
    <div class="text-center">
      <div class="flex justify-center space-x-4 text-xs text-slate-500">
        <%= link_to "홈으로", root_path, class: "hover:text-slate-700" %>
        <span>•</span>
        <a href="#" class="hover:text-slate-700">도움말</a>
        <span>•</span>
        <a href="#" class="hover:text-slate-700">개인정보</a>
      </div>
    </div>
  </div>
</div>
