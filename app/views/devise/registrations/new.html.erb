<% content_for :title, "회원가입 - DentalNow" %>

<!-- Role Detection -->
<% role = params[:role] || 'jobseeker' %>
<% is_hospital = role == 'hospital' %>

<!-- Sign Up Page -->
<div class="min-h-screen bg-gradient-to-br from-green-50 via-white to-emerald-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <!-- Header -->
    <div class="text-center">
      <div class="mx-auto h-16 w-16 bg-gradient-to-r <%= is_hospital ? 'from-orange-500 to-red-500' : 'from-green-500 to-emerald-600' %> rounded-2xl flex items-center justify-center mb-6 shadow-lg">
        <span class="text-white font-bold text-2xl"><%= is_hospital ? '🏥' : '🦷' %></span>
      </div>
      <h2 class="text-3xl font-bold text-gray-900 mb-2">
        <%= is_hospital ? '병원 회원가입' : '구직자 회원가입' %> ✨
      </h2>
      <p class="text-gray-600">
        <%= is_hospital ? 
              '최고의 치과 인력을 찾아 <strong>병원 성장</strong>을 이뤄보세요' : 
              '꿈의 치과 일자리를 찾아 <strong>커리어 성장</strong>을 시작하세요' %>
      </p>
    </div>

    <!-- Sign Up Form -->
    <div class="bg-white rounded-3xl shadow-xl p-8 border border-gray-100">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true, html: { class: "space-y-6" }) do |f| %>
        
        <!-- Error Messages -->
        <% if resource.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-xl p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  입력 정보를 확인해주세요
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <% resource.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Hidden Role Field -->
        <%= f.hidden_field :role, value: role %>

        <!-- Name Field -->
        <div>
          <%= f.label :name, is_hospital ? "병원명" : "이름", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <%= f.text_field :name, 
                placeholder: is_hospital ? "○○치과의원" : "홍길동",
                class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm" %>
          </div>
        </div>

        <!-- Phone Field -->
        <div>
          <%= f.label :phone, "연락처", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <%= f.telephone_field :phone, 
                placeholder: "010-1234-5678",
                class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm" %>
          </div>
        </div>

        <!-- Email Field -->
        <div>
          <%= f.label :email, "이메일 주소", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
              </svg>
            </div>
            <%= f.email_field :email, 
                autofocus: true, 
                autocomplete: "email",
                placeholder: is_hospital ? "admin@hospital.com" : "yourname@email.com",
                class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm" %>
          </div>
        </div>

        <!-- Password Field -->
        <div>
          <%= f.label :password, "비밀번호", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500 mb-2">최소 <%= @minimum_password_length %>자 이상 입력해주세요</p>
          <% end %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <%= f.password_field :password, 
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm" %>
          </div>
        </div>

        <!-- Password Confirmation Field -->
        <div>
          <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <%= f.password_field :password_confirmation, 
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors sm:text-sm" %>
          </div>
        </div>

        <!-- Terms Agreement -->
        <div class="bg-gray-50 rounded-xl p-4">
          <div class="flex items-start">
            <div class="flex items-center h-5">
              <input type="checkbox" required class="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded">
            </div>
            <div class="ml-3 text-sm">
              <p class="text-gray-700">
                <strong>서비스 이용약관</strong> 및 <strong>개인정보처리방침</strong>에 동의합니다.
                <span class="text-red-500">*</span>
              </p>
              <p class="text-xs text-gray-500 mt-1">
                회원가입 시 DentalNow의 모든 서비스를 이용하실 수 있습니다.
              </p>
            </div>
          </div>
        </div>

        <!-- Sign Up Button -->
        <div>
          <%= f.submit is_hospital ? "🏥 병원 회원가입" : "🦷 구직자 회원가입", 
              class: "group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r #{is_hospital ? 'from-orange-500 to-red-500 hover:from-orange-600 hover:to-red-600' : 'from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700'} focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" %>
        </div>

        <!-- Divider -->
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">또는</span>
          </div>
        </div>

        <!-- Login Link -->
        <div class="text-center">
          <p class="text-sm text-gray-600">
            이미 계정이 있으신가요?
            <%= link_to "로그인하기", new_session_path(resource_name), 
                class: "font-medium text-green-600 hover:text-green-500 ml-1" %>
          </p>
        </div>

        <!-- Role Switch -->
        <div class="text-center">
          <p class="text-xs text-gray-500 mb-3">다른 유형으로 가입하기</p>
          <div class="flex justify-center space-x-4">
            <%= link_to new_registration_path(resource_name, role: 'jobseeker'), 
                class: "#{role == 'jobseeker' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} px-3 py-2 rounded-lg text-xs font-medium transition-colors" do %>
              🦷 구직자
            <% end %>
            <%= link_to new_registration_path(resource_name, role: 'hospital'), 
                class: "#{role == 'hospital' ? 'bg-orange-100 text-orange-800' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'} px-3 py-2 rounded-lg text-xs font-medium transition-colors" do %>
              🏥 병원
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Additional Links -->
    <div class="text-center space-y-4">
      <div class="flex justify-center space-x-6 text-sm text-gray-500">
        <%= link_to "홈으로", root_path, class: "hover:text-gray-700" %>
        <span>•</span>
        <a href="#" class="hover:text-gray-700">고객지원</a>
        <span>•</span>
        <a href="#" class="hover:text-gray-700">개인정보처리방침</a>
      </div>
      
      <div class="text-xs text-gray-400">
        🔒 개인정보는 안전하게 암호화되어 보호됩니다
      </div>
    </div>
  </div>
</div>
