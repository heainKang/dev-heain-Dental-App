<% content_for :title, "병원 정보 수정 - DentalNow" %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <!-- Header Section -->
  <div class="relative overflow-hidden bg-gradient-to-r from-blue-900 via-blue-800 to-indigo-900">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-blue-900 mix-blend-multiply"></div>
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,<svg width=\\\"40\\\" height=\\\"40\\\" viewBox=\\\"0 0 40 40\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\"><g fill=\\\"none\\\" fill-rule=\\\"evenodd\\\"><g fill=\\\"%23ffffff\\\" fill-opacity=\\\"0.05\\\"><circle cx=\\\"20\\\" cy=\\\"20\\\" r=\\\"2\\\"/><path d=\\\"M20 18v4m-2-2h4\\\"/></g></g></svg>'); background-size: 40px 40px;"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center">
        <div class="inline-flex items-center bg-white/10 backdrop-blur-sm rounded-full px-6 py-3 mb-6">
          <span class="w-3 h-3 bg-cyan-400 rounded-full animate-pulse mr-3"></span>
          <span class="text-white font-medium">🏥 병원 정보 수정</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          <span class="block"><%= @hospital.name %></span>
          <span class="bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">정보 업데이트</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
          병원 정보를 최신 상태로 유지하여 더 나은 매칭을 받아보세요
        </p>
      </div>
    </div>
  </div>

  <!-- Edit Form -->
  <div class="relative -mt-32 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
      <!-- Form Header -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 px-8 py-8 border-b border-gray-100">
        <div class="flex items-center">
          <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center mr-6 shadow-lg">
            <span class="text-white text-2xl font-bold">🏥</span>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">병원 정보 수정</h2>
            <p class="text-gray-600">정확한 정보로 업데이트하여 신뢰도를 높여보세요</p>
          </div>
        </div>
      </div>

      <!-- Form Body -->
      <div class="px-8 py-8">
        <%= form_with model: @hospital, local: true, html: { class: "space-y-8" } do |f| %>
          
          <!-- Error Messages -->
          <% if @hospital.errors.any? %>
            <div class="bg-red-50 border-l-4 border-red-400 p-6 rounded-r-xl">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-6 w-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-lg font-medium text-red-800 mb-2">입력 정보를 확인해주세요</h3>
                  <ul class="text-red-700 space-y-1">
                    <% @hospital.errors.full_messages.each do |message| %>
                      <li class="flex items-center">
                        <span class="w-1.5 h-1.5 bg-red-400 rounded-full mr-2"></span>
                        <%= message %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Success Message -->
          <% if notice %>
            <div class="bg-green-50 border-l-4 border-green-400 p-6 rounded-r-xl">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-green-700 font-medium"><%= notice %></p>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Basic Information Section -->
          <div class="bg-gray-50 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-6 flex items-center">
              <span class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                <span class="text-blue-600 text-sm">📋</span>
              </span>
              기본 정보
            </h3>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <%= f.label :name, "병원명 *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_field :name, 
                    placeholder: "○○치과의원",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
              </div>
              
              <div class="md:col-span-2">
                <%= f.label :address, "주소 *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_area :address, 
                    rows: 2,
                    placeholder: "서울특별시 강남구 역삼동 123-45 ABC빌딩 2층",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-none" %>
              </div>
              
              <div>
                <%= f.label :phone, "대표전화 *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.telephone_field :phone, 
                    placeholder: "02-1234-5678",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
              </div>
              
              <div>
                <%= f.label :business_registration_number, "사업자등록번호", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_field :business_registration_number, 
                    placeholder: "123-45-67890",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
                <p class="text-xs text-gray-500 mt-1">신뢰도 향상을 위해 입력해주세요 (선택사항)</p>
              </div>
            </div>
          </div>

          <!-- Additional Information Section -->
          <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-6 flex items-center">
              <span class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center mr-3">
                <span class="text-indigo-600 text-sm">✨</span>
              </span>
              추가 정보
            </h3>
            
            <div class="space-y-6">
              <div>
                <%= f.label :website, "병원 홈페이지", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.url_field :website, 
                    placeholder: "https://www.hospital.com",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
              </div>
              
              <div>
                <%= f.label :description, "병원 소개", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_area :description, 
                    rows: 4,
                    placeholder: "저희 병원의 특장점, 보유 장비, 진료 철학 등을 간단히 소개해주세요.",
                    class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-none" %>
                <p class="text-xs text-gray-500 mt-1">구직자들에게 보여질 병원 소개글입니다</p>
              </div>
            </div>
          </div>

          <!-- Current Status Section -->
          <div class="bg-emerald-50 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
              <span class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center mr-3">
                <span class="text-emerald-600 text-sm">📊</span>
              </span>
              현재 현황
            </h3>
            
            <div class="grid md:grid-cols-3 gap-4">
              <div class="text-center">
                <div class="text-2xl font-bold text-emerald-600 mb-1"><%= @hospital.active_jobs_count %></div>
                <div class="text-sm text-gray-600">활성 공고</div>
              </div>
              
              <div class="text-center">
                <div class="text-2xl font-bold text-blue-600 mb-1">
                  <% rating = @hospital.average_rating %>
                  <%= rating > 0 ? number_with_precision(rating, precision: 1) : "-" %>
                </div>
                <div class="text-sm text-gray-600">평균 평점</div>
              </div>
              
              <div class="text-center">
                <div class="text-2xl font-bold text-purple-600 mb-1"><%= @hospital.reviews_count || 0 %></div>
                <div class="text-sm text-gray-600">리뷰 수</div>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex flex-col sm:flex-row gap-4 pt-6">
            <%= link_to hospital_path(@hospital), 
                class: "w-full sm:w-auto bg-gray-100 text-gray-700 px-8 py-4 rounded-xl font-semibold text-center hover:bg-gray-200 transition-all duration-300 flex items-center justify-center" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              돌아가기
            <% end %>
            
            <%= f.submit "🏥 수정 완료", 
                class: "w-full sm:flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:from-blue-700 hover:to-indigo-700 transition-all duration-300 transform hover:scale-[1.02] shadow-xl hover:shadow-2xl" %>
          </div>

          <div class="text-center pt-4">
            <p class="text-sm text-gray-500">
              🔒 모든 정보는 안전하게 암호화되어 보호됩니다
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
