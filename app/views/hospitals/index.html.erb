<% content_for :title, "병원 목록 - DentalNow" %>

<div class="min-h-screen bg-gray-50">
  <!-- 헤더 섹션 -->
  <div class="bg-gradient-to-br from-emerald-500 to-teal-600 px-4 sm:px-6 lg:px-8 pt-8 pb-12">
    <div class="text-center text-white">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl backdrop-blur-sm mb-4">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
        </svg>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold mb-2">등록된 병원</h1>
      <p class="text-emerald-100">DentalNow 파트너 치과들을 만나보세요</p>
    </div>
  </div>

  <div class="px-4 sm:px-6 lg:px-8 -mt-6 pb-8">
    <% if @hospitals&.any? %>
      <!-- 병원 카드 리스트 -->
      <div class="space-y-4">
        <% @hospitals.each do |hospital| %>
          <div class="mobile-card hover:shadow-lg transition-all duration-200">
            <!-- 병원 헤더 -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-start space-x-3">
                <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-gray-900 mb-1"><%= hospital.name %></h3>
                  <div class="flex items-center space-x-1 text-gray-500 text-sm mb-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    </svg>
                    <span><%= hospital.address %></span>
                  </div>
                  <div class="flex items-center space-x-1 text-gray-500 text-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span><%= hospital.phone %></span>
                  </div>
                </div>
              </div>
              
              <!-- 인증 배지 -->
              <div class="bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full text-xs font-bold">
                ✓ 인증
              </div>
            </div>

            <!-- 병원 통계 -->
            <div class="bg-emerald-50 rounded-2xl p-4 mb-4">
              <div class="grid grid-cols-3 gap-4 text-center">
                <div>
                  <div class="text-xs text-emerald-600 mb-1">활성 공고</div>
                  <div class="text-xl font-bold text-emerald-800"><%= hospital.active_jobs_count %></div>
                </div>
                <div>
                  <div class="text-xs text-emerald-600 mb-1">평점</div>
                  <div class="text-xl font-bold text-emerald-800">
                    <% rating = hospital.average_rating %>
                    <%= rating > 0 ? number_with_precision(rating, precision: 1) : "-" %>
                  </div>
                </div>
                <div>
                  <div class="text-xs text-emerald-600 mb-1">리뷰</div>
                  <div class="text-xl font-bold text-emerald-800">
                    <%= hospital.reviews_count || 0 %>
                  </div>
                </div>
              </div>
            </div>

            <!-- 설명 -->
            <% if hospital.description.present? %>
              <p class="text-gray-700 mb-4 text-sm leading-relaxed line-clamp-3">
                <%= hospital.description %>
              </p>
            <% end %>

            <!-- 하단 정보 및 액션 -->
            <div class="flex items-center justify-between">
              <div class="text-xs text-gray-500 flex items-center space-x-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span>등록: <%= hospital.created_at.strftime('%Y.%m.%d') %></span>
              </div>
              
              <%= link_to hospital_path(hospital), 
                  class: "px-4 py-2 bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-xl text-sm font-medium hover:from-emerald-600 hover:to-teal-700 transition-all shadow-lg" do %>
                병원 보기
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      
      <!-- 더 많은 병원 로딩 버튼 (향후 구현) -->
      <div class="text-center mt-8">
        <button class="mobile-btn mobile-btn-secondary max-w-xs mx-auto">
          더 많은 병원 보기
        </button>
      </div>
    <% else %>
      <!-- 빈 상태 -->
      <div class="text-center py-16">
        <div class="mobile-card max-w-md mx-auto">
          <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">등록된 병원이 없습니다</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">
            첫 번째로 병원을 등록해보세요!<br>
            구인공고를 올리고 우수한 인재를 찾아보세요.
          </p>
          
          <div class="space-y-3">
            <%= link_to new_hospital_path, class: "mobile-btn mobile-btn-primary w-full" do %>
              🏥 병원 등록하기
            <% end %>
            <%= link_to root_path, class: "mobile-btn mobile-btn-secondary w-full" do %>
              🏠 홈으로 돌아가기
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
