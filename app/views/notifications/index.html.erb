<% content_for :title, "알림 - DentalNow" %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center bg-white/80 backdrop-blur-sm rounded-full px-6 py-3 mb-6 shadow-lg">
        <span class="w-3 h-3 bg-blue-500 rounded-full animate-pulse mr-3"></span>
        <span class="text-blue-700 font-medium">🔔 알림</span>
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold text-blue-900 mb-4">
        알림 센터
      </h1>
      <p class="text-blue-700 text-lg">
        중요한 업데이트와 새로운 소식을 확인하세요
      </p>
    </div>

    <!-- Notifications Container -->
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 px-8 py-6 border-b border-gray-100">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-bold text-gray-900">알림 목록</h2>
            <p class="text-sm text-gray-600 mt-1">
              <span class="font-medium text-blue-600"><%= @unread_count %></span>개의 읽지 않은 알림
            </p>
          </div>
          
          <% if @unread_count > 0 %>
            <%= button_to "모두 읽음 처리", notifications_path, 
                method: :patch, 
                params: { action_type: 'mark_all_as_read' },
                class: "mobile-btn mobile-btn-primary mobile-btn-sm",
                data: { 
                  "turbo-method": :patch,
                  confirm: "모든 알림을 읽음으로 처리하시겠습니까?"
                } %>
          <% end %>
        </div>
      </div>

      <!-- Notifications List -->
      <% if @notifications.any? %>
        <div class="divide-y divide-gray-100">
          <% @notifications.each do |notification| %>
            <div class="px-8 py-6 <%= 'bg-blue-50/50' if notification.unread? %> hover:bg-gray-50 transition-colors">
              <div class="flex items-start space-x-4">
                <!-- Notification Icon -->
                <div class="flex-shrink-0 mt-1">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center
                    <%= case notification.notification_type
                        when 'job_applied' then 'bg-blue-100'
                        when 'job_accepted' then 'bg-green-100'
                        when 'job_rejected' then 'bg-red-100'
                        when 'new_job_posted' then 'bg-yellow-100'
                        when 'profile_reminder' then 'bg-purple-100'
                        else 'bg-gray-100'
                        end %>">
                    <span class="text-lg">
                      <%= case notification.notification_type
                          when 'job_applied' then '📝'
                          when 'job_accepted' then '✅'
                          when 'job_rejected' then '❌'
                          when 'new_job_posted' then '🆕'
                          when 'profile_reminder' then '👤'
                          when 'system_announcement' then '📢'
                          else '🔔'
                          end %>
                    </span>
                  </div>
                </div>
                
                <!-- Notification Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <h3 class="text-lg font-semibold text-gray-900 mb-1">
                        <%= notification.title %>
                        <% if notification.unread? %>
                          <span class="inline-block w-2 h-2 bg-blue-500 rounded-full ml-2"></span>
                        <% end %>
                      </h3>
                      <p class="text-gray-700 mb-2"><%= notification.message %></p>
                      <div class="flex items-center space-x-4 text-sm text-gray-500">
                        <span>⏰ <%= time_ago_in_words(notification.created_at) %>전</span>
                        <span class="px-2 py-1 rounded-full text-xs font-medium
                          <%= case notification.notification_type
                              when 'job_applied' then 'bg-blue-100 text-blue-800'
                              when 'job_accepted' then 'bg-green-100 text-green-800'
                              when 'job_rejected' then 'bg-red-100 text-red-800'
                              when 'new_job_posted' then 'bg-yellow-100 text-yellow-800'
                              when 'profile_reminder' then 'bg-purple-100 text-purple-800'
                              else 'bg-gray-100 text-gray-800'
                              end %>">
                          <%= case notification.notification_type
                              when 'job_applied' then '지원 완료'
                              when 'job_accepted' then '지원 승인'
                              when 'job_rejected' then '지원 거절'
                              when 'new_job_posted' then '새 공고'
                              when 'profile_reminder' then '프로필 알림'
                              when 'system_announcement' then '시스템 공지'
                              else notification.notification_type.humanize
                              end %>
                        </span>
                      </div>
                    </div>
                    
                    <!-- Actions -->
                    <div class="flex items-center space-x-2 ml-4">
                      <% if notification.notifiable %>
                        <%= link_to notification_path(notification), 
                            class: "text-blue-600 hover:text-blue-800 text-sm font-medium" do %>
                          📋 보기
                        <% end %>
                      <% end %>
                      
                      <% if notification.unread? %>
                        <%= button_to notification_path(notification), 
                            method: :patch, 
                            params: { action_type: 'mark_as_read' },
                            class: "text-gray-600 hover:text-gray-800 text-sm font-medium border-0 bg-transparent cursor-pointer",
                            data: { "turbo-method": :patch } do %>
                          읽음 처리
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-20">
          <div class="w-24 h-24 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-4xl">🔔</span>
          </div>
          <h3 class="text-2xl font-bold text-blue-900 mb-4">아직 알림이 없습니다</h3>
          <p class="text-blue-600 mb-8">
            새로운 구인공고나 지원 결과가 있으면<br>
            이곳에서 알림을 받을 수 있습니다.
          </p>
          <div class="space-y-3">
            <%= link_to jobs_path, class: "inline-block bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3 px-8 rounded-xl font-medium hover:from-blue-700 hover:to-indigo-700 transition-all duration-300 transform hover:scale-105" do %>
              🔍 구인공고 보러가기
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Back to Dashboard -->
    <div class="text-center mt-8">
      <%= link_to dashboard_path, 
          class: "inline-flex items-center text-blue-600 hover:text-blue-800 font-medium" do %>
        ← 대시보드로 돌아가기
      <% end %>
    </div>
  </div>
</div>
