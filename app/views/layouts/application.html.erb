<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DentalNow - 치과인력 매칭 플랫폼" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#3B82F6">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- 한글 웹폰트 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@100;300;400;500;700;900&display=swap" rel="stylesheet">

    <%# Stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <!-- 폰트 스타일 -->
    <style>
      * {
        font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      
      body {
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
      }
      
      .font-bold {
        font-weight: 700;
      }
      
      .font-semibold {
        font-weight: 500;
      }
      
      .font-medium {
        font-weight: 500;
      }
      
      .font-light {
        font-weight: 300;
      }
      
      /* 부드러운 카드 효과 */
      .soft-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: all 0.3s ease;
      }
      
      .soft-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
      }
      
      /* 부드러운 버튼 */
      .soft-btn {
        border-radius: 16px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      }
      
      .soft-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      }
      
      /* 부드러운 태그 */
      .soft-tag {
        border-radius: 12px;
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        backdrop-filter: blur(5px);
      }
      
      /* 부드러운 그라데이션 */
      .soft-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
    </style>
  </head>

  <body class="min-h-screen bg-white antialiased">
    <!-- 상단 헤더 - 부드러운 스타일 -->
    <header class="bg-white/80 backdrop-blur-md border-b border-gray-100/50 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- 로고 -->
                      <div class="flex items-center">
              <%= link_to root_path, class: "flex items-center space-x-3 hover:scale-105 transition-all duration-300" do %>
                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg">
                  <span class="text-white font-bold text-lg">🦷</span>
                </div>
                <span class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">DentalNow</span>
              <% end %>
            </div>

          <!-- 메인 네비게이션 -->
          <nav class="hidden md:flex items-center space-x-8">
            <%= link_to "DentalNow 소개", "#", 
                class: "text-gray-700 hover:text-blue-600 font-medium transition-colors duration-200" %>
            <%= link_to "우리 지역 일자리", jobs_path, 
                class: "text-gray-700 hover:text-blue-600 font-medium transition-colors duration-200" %>
            <%= link_to "대규모 채용", "#", 
                class: "text-gray-700 hover:text-blue-600 font-medium transition-colors duration-200" %>
            <%= link_to "소규모 채용", "#", 
                class: "text-gray-700 hover:text-blue-600 font-medium transition-colors duration-200" %>
          </nav>

          <!-- 우측 메뉴 -->
          <div class="flex items-center space-x-4">
            <% if user_signed_in? %>
              <!-- 로그인된 사용자 메뉴 -->
              <div class="relative group">
                <button class="flex items-center space-x-2 text-gray-700 hover:text-blue-600 font-medium">
                  <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                    <span class="text-blue-600 font-semibold text-sm">
                      <%= current_user.name&.first&.upcase || 'U' %>
                    </span>
                  </div>
                  <span class="hidden sm:block"><%= current_user.name || '사용자' %>님</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                
                <!-- 드롭다운 메뉴 -->
                <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                  <div class="py-2">
                                         <%= link_to dashboard_path, 
                         class: "block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-blue-600" do %>
                       대시보드
                     <% end %>
                    <%= link_to "#", 
                        class: "block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-blue-600" do %>
                      내 정보
                    <% end %>
                    <div class="border-t border-gray-100 my-1"></div>
                    <%= button_to destroy_user_session_path, method: :delete,
                        class: "w-full text-left px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-red-600" do %>
                      로그아웃
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <!-- 비로그인 사용자 메뉴 -->
              <%= link_to "로그인", new_user_session_path, 
                  class: "text-gray-700 hover:text-blue-600 font-medium transition-colors duration-200" %>
              <%= link_to "회원가입", new_user_registration_path, 
                  class: "mobile-btn mobile-btn-primary mobile-btn-sm" %>
            <% end %>

            <!-- 모바일 메뉴 버튼 -->
            <button class="md:hidden p-2 text-gray-700 hover:text-blue-600" onclick="toggleMobileMenu()">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- 모바일 메뉴 -->
        <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 py-4">
          <div class="space-y-2">
            <%= link_to "DentalNow 소개", "#", 
                class: "block py-2 text-gray-700 hover:text-blue-600 font-medium" %>
            <%= link_to "우리 지역 일자리", jobs_path, 
                class: "block py-2 text-gray-700 hover:text-blue-600 font-medium" %>
            <%= link_to "대규모 채용", "#", 
                class: "block py-2 text-gray-700 hover:text-blue-600 font-medium" %>
            <%= link_to "소규모 채용", "#", 
                class: "block py-2 text-gray-700 hover:text-blue-600 font-medium" %>
          </div>
        </div>
      </div>
    </header>

    <!-- 메인 콘텐츠 -->
    <main class="flex-1">
      <!-- 알림 메시지 -->
      <% if notice %>
        <div class="bg-green-50 border-l-4 border-green-400 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-green-700"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-50 border-l-4 border-red-400 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <!-- 푸터 - 동네알바 스타일 -->
    <footer class="bg-gray-50 border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid md:grid-cols-4 gap-8">
          <!-- 회사 정보 -->
          <div>
            <div class="flex items-center space-x-2 mb-4">
              <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm">D</span>
              </div>
              <span class="text-xl font-bold text-gray-900">DentalNow</span>
            </div>
            <p class="text-gray-600 text-sm mb-4">
              전문적이고 신뢰할 수 있는<br>
              치과 인력 매칭 플랫폼
            </p>
          </div>

          <!-- 서비스 -->
          <div>
            <h3 class="font-semibold text-gray-900 mb-4">서비스</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><%= link_to "치과 인력 찾기", jobs_path, class: "hover:text-blue-600" %></li>
              <li><%= link_to "병원 등록", "#", class: "hover:text-blue-600" %></li>
              <li><%= link_to "이용 가이드", "#", class: "hover:text-blue-600" %></li>
            </ul>
          </div>

          <!-- 고객지원 -->
          <div>
            <h3 class="font-semibold text-gray-900 mb-4">고객지원</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><%= link_to "고객센터", "#", class: "hover:text-blue-600" %></li>
              <li><%= link_to "자주 묻는 질문", "#", class: "hover:text-blue-600" %></li>
              <li><%= link_to "공지사항", "#", class: "hover:text-blue-600" %></li>
            </ul>
          </div>

          <!-- 앱 다운로드 -->
          <div>
            <h3 class="font-semibold text-gray-900 mb-4">앱 다운로드</h3>
            <div class="space-y-2">
              <button class="w-full bg-black text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors">
                App Store
              </button>
              <button class="w-full bg-black text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors">
                Google Play
              </button>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-200 mt-8 pt-8 text-center">
          <p class="text-gray-500 text-sm">
            © 2024 DentalNow. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <!-- JavaScript -->
    <script>
      function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        menu.classList.toggle('hidden');
      }
    </script>
  </body>
</html>
