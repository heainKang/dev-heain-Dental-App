<% content_for :title, "DentalNow - 치과 인력 매칭 플랫폼" %>

<!-- 부드러운 히어로 섹션 -->
<div class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
    <div class="text-center">
      <div class="mb-8">
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-gradient-to-r from-blue-100 to-purple-100 text-blue-800 mb-4">
          ✨ 치과 전문 매칭 플랫폼
        </span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6">
        <span class="bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">
          치과 인력 매칭의<br>새로운 표준
        </span>
      </h1>
      <p class="text-xl text-gray-700 mb-10 max-w-3xl mx-auto leading-relaxed">
        🏥 전문적이고 신뢰할 수 있는 치과 인력 매칭 플랫폼으로<br>
        💼 병원과 인력을 효과적으로 연결합니다
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <% if user_signed_in? %>
          <%= link_to "🔍 구인 공고 보기", jobs_path, 
              class: "mobile-btn mobile-btn-primary mobile-btn-lg" %>
          <%= link_to "📊 내 대시보드", dashboard_path, 
              class: "mobile-btn mobile-btn-secondary mobile-btn-lg" %>
        <% else %>
          <%= link_to "🏥 병원 회원가입", new_user_registration_path(role: :hospital), 
              class: "mobile-btn mobile-btn-primary mobile-btn-lg" %>
          <%= link_to "👩‍⚕️ 직원 회원가입", new_user_registration_path(role: :staff), 
              class: "mobile-btn mobile-btn-secondary mobile-btn-lg" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- 파트너 병원들 슬라이더 섹션 -->
<div class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold mb-4">
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          🤝 DentalNow와 함께하는 병원들
        </span>
      </h2>
      <p class="text-gray-600 text-lg">믿을 수 있는 파트너 병원들이 함께 합니다 ✨</p>
    </div>
    
          <div class="overflow-hidden">
        <div class="animate-scroll flex space-x-8 items-center">
          <!-- 파트너 병원 로고들 -->
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">🏥 서울대치과병원</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-green-600 to-blue-600 bg-clip-text text-transparent">🦷 연세치과</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">✨ 고려치과</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent">🌟 경희치과대학병원</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-teal-600 to-green-600 bg-clip-text text-transparent">💎 이대목동병원</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">🏆 삼성서울병원</span>
          </div>
                  <!-- 반복을 위한 복사본 -->
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">🏥 서울대치과병원</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-green-600 to-blue-600 bg-clip-text text-transparent">🦷 연세치과</span>
          </div>
          <div class="soft-card flex items-center justify-center p-8 min-w-[240px] h-24">
            <span class="text-lg font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">✨ 고려치과</span>
          </div>
      </div>
    </div>
  </div>
</div>

<!-- 서비스 소개 섹션 -->
<div class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-purple-50/50 to-pink-50/50"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold mb-4">
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          💡 서비스 특징
        </span>
      </h2>
      <p class="text-gray-600 text-lg">DentalNow가 제공하는 차별화된 서비스를 만나보세요 ✨</p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- 병원 등록 -->
      <div class="soft-card text-center p-8 group">
        <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-blue-600 rounded-3xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
          <span class="text-3xl">🏥</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">병원 등록</h3>
        <p class="text-gray-600 leading-relaxed">간편하게 병원을 등록하고 전문 인력을 찾아보세요</p>
      </div>
      
      <!-- 인재 찾기 -->
      <div class="soft-card text-center p-8 group">
        <div class="w-20 h-20 bg-gradient-to-br from-green-400 to-emerald-600 rounded-3xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
          <span class="text-3xl">👨‍⚕️</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">인재 찾기</h3>
        <p class="text-gray-600 leading-relaxed">검증된 치과 전문 인력을 빠르게 찾아보세요</p>
      </div>
      
      <!-- 매칭 서비스 -->
      <div class="soft-card text-center p-8 group">
        <div class="w-20 h-20 bg-gradient-to-br from-purple-400 to-pink-600 rounded-3xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
          <span class="text-3xl">💝</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">스마트 매칭</h3>
        <p class="text-gray-600 leading-relaxed">AI 기반으로 최적의 매칭을 자동으로 제공합니다</p>
      </div>
      
      <!-- 안전한 거래 -->
      <div class="soft-card text-center p-8 group">
        <div class="w-20 h-20 bg-gradient-to-br from-orange-400 to-red-600 rounded-3xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
          <span class="text-3xl">🛡️</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">안전한 거래</h3>
        <p class="text-gray-600 leading-relaxed">투명하고 안전한 계약 시스템을 보장합니다</p>
      </div>
    </div>
  </div>
</div>

<!-- 실시간 통계 섹션 -->
<div class="bg-gray-900 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-4">실시간 현황</h2>
      <p class="text-gray-300">지금 이 순간에도 활발하게 이루어지는 매칭들</p>
    </div>
    
    <div class="grid sm:grid-cols-3 gap-6">
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/20">
        <div class="text-4xl font-bold text-white mb-2">1,247</div>
        <div class="text-gray-300">등록된 병원</div>
      </div>
      
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/20">
        <div class="text-4xl font-bold text-white mb-2">3,892</div>
        <div class="text-gray-300">활성 인력</div>
      </div>
      
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/20">
        <div class="text-4xl font-bold text-white mb-2">15,632</div>
        <div class="text-gray-300">성공 매칭</div>
      </div>
    </div>
  </div>
</div>

<!-- 앱 다운로드 섹션 -->
<div class="bg-blue-600 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold text-white mb-4">모바일 앱으로 더 편리하게</h2>
    <p class="text-blue-100 mb-8 text-lg">언제 어디서나 DentalNow를 이용하세요</p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <button class="mobile-btn mobile-btn-secondary bg-white/20 backdrop-blur-sm text-white border-white/30 hover:bg-white/30 px-8 py-4 font-semibold flex items-center justify-center">
        <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.05 20.28c-.98.95-2.05.88-3.08.35-1.09-.56-2.09-.56-3.23 0-1.44.74-2.18.63-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
        </svg>
        App Store
