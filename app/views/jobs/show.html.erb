<% content_for :title, "#{@job.title} - DentalNow" %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Back Button -->
    <div class="mb-6">
      <%= link_to jobs_path, class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-medium" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        구인공고 목록으로 돌아가기
      <% end %>
    </div>

    <!-- Job Header -->
    <div class="bg-white rounded-3xl shadow-xl p-8 mb-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between mb-6">
        <div class="flex-1">
          <div class="flex items-center mb-4">
            <h1 class="text-3xl md:text-4xl font-bold text-blue-900 mr-4"><%= @job.title %></h1>
            <% if @job.is_urgent? %>
              <span class="bg-red-100 text-red-800 px-4 py-2 rounded-full text-sm font-bold animate-pulse">
                🔥 긴급모집
              </span>
            <% end %>
          </div>
          
          <div class="space-y-2 mb-6">
            <div class="flex items-center text-blue-700">
              <span class="text-xl mr-3">🏥</span>
              <span class="text-xl font-medium"><%= @job.hospital.name %></span>
            </div>
            <div class="flex items-center text-blue-600">
              <span class="text-lg mr-3">📍</span>
              <span><%= @job.hospital.address %></span>
            </div>
            <div class="flex items-center text-blue-600">
              <span class="text-lg mr-3">📞</span>
              <span><%= @job.hospital.phone %></span>
            </div>
          </div>
        </div>
        
        <!-- Salary Card -->
        <div class="bg-gradient-to-r from-blue-100 to-indigo-100 rounded-2xl p-6 lg:ml-8 lg:min-w-[300px]">
          <div class="text-center">
            <p class="text-blue-600 text-sm font-medium mb-2">시급</p>
            <p class="text-4xl font-bold text-blue-900 mb-1">₩<%= number_with_delimiter(@job.hourly_rate) %></p>
            <p class="text-blue-700 text-sm">총 급여: ₩<%= number_with_delimiter(@job.total_payment) %></p>
          </div>
        </div>
      </div>

      <!-- Job Details Grid -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="space-y-4">
          <div class="bg-blue-50 rounded-xl p-4">
            <h3 class="font-bold text-blue-900 mb-2">📅 근무 일정</h3>
            <p class="text-blue-800"><%= @job.work_date.strftime('%Y년 %m월 %d일 (%A)') %></p>
            <p class="text-blue-700 text-sm">
              <%= @job.start_time.strftime('%H:%M') %> - <%= @job.end_time.strftime('%H:%M') %>
              (<%= @job.duration_hours %>시간)
            </p>
          </div>
          
          <div class="bg-green-50 rounded-xl p-4">
            <h3 class="font-bold text-green-900 mb-2">💼 모집 상태</h3>
            <span class="inline-block px-3 py-1 rounded-full text-sm font-medium
              <%= case @job.status
                  when 'active' then 'bg-green-100 text-green-800'
                  when 'filled' then 'bg-yellow-100 text-yellow-800'
                  when 'completed' then 'bg-gray-100 text-gray-800'
                  when 'cancelled' then 'bg-red-100 text-red-800'
                  else 'bg-gray-100 text-gray-800'
                  end %>">
              <%= case @job.status
                  when 'active' then '모집중'
                  when 'filled' then '모집완료'
                  when 'completed' then '근무완료'
                  when 'cancelled' then '모집취소'
                  else @job.status
                  end %>
            </span>
          </div>
        </div>
        
        <div class="space-y-4">
          <div class="bg-purple-50 rounded-xl p-4">
            <h3 class="font-bold text-purple-900 mb-2">🏥 병원 정보</h3>
            <p class="text-purple-800 mb-1"><%= @job.hospital.name %></p>
            <% if @job.hospital.description.present? %>
              <p class="text-purple-700 text-sm"><%= @job.hospital.description %></p>
            <% end %>
          </div>
          
          <div class="bg-orange-50 rounded-xl p-4">
            <h3 class="font-bold text-orange-900 mb-2">⏰ 등록일</h3>
            <p class="text-orange-800"><%= @job.created_at.strftime('%Y년 %m월 %d일') %></p>
            <p class="text-orange-700 text-sm"><%= time_ago_in_words(@job.created_at) %>전 등록</p>
          </div>
        </div>
      </div>

      <!-- Job Description -->
      <div class="bg-gray-50 rounded-xl p-6 mb-8">
        <h3 class="font-bold text-gray-900 mb-4 text-xl">📋 업무 내용</h3>
        <div class="prose max-w-none">
          <p class="text-gray-700 leading-relaxed whitespace-pre-line"><%= @job.description %></p>
        </div>
      </div>

      <!-- Application Section -->
      <% if user_signed_in? %>
        <% if current_user.jobseeker? %>
          <div class="border-t border-gray-200 pt-8">
            <div class="text-center">
              <% if @already_applied %>
                <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6">
                  <div class="flex items-center justify-center mb-4">
                    <span class="text-4xl">✅</span>
                  </div>
                  <h3 class="text-xl font-bold text-yellow-800 mb-2">이미 지원한 공고입니다</h3>
                  <p class="text-yellow-700 mb-4">병원에서 검토 후 연락드릴 예정입니다.</p>
                  <%= link_to "지원 내역 보기", my_applications_path, class: "bg-yellow-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-yellow-700 transition-colors" %>
                </div>
              <% elsif @job.can_apply? %>
                <div class="bg-blue-50 border border-blue-200 rounded-xl p-6">
                  <div class="flex items-center justify-center mb-4">
                    <span class="text-4xl">💼</span>
                  </div>
                  <h3 class="text-xl font-bold text-blue-900 mb-2">지금 바로 지원하세요!</h3>
                  <p class="text-blue-700 mb-6">프로필을 검토 후 병원에서 직접 연락드립니다.</p>
                  <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <% if current_user.profile&.persisted? %>
                      <%= link_to edit_profile_path(current_user.profile), class: "bg-gray-100 text-blue-700 px-6 py-3 rounded-xl font-medium hover:bg-gray-200 transition-colors" do %>
                        👤 프로필 확인
                      <% end %>
                    <% else %>
                      <%= link_to new_profile_path, class: "bg-gray-100 text-blue-700 px-6 py-3 rounded-xl font-medium hover:bg-gray-200 transition-colors" do %>
                        👤 프로필 생성
                      <% end %>
                    <% end %>
                    <%= link_to apply_job_path(@job), data: { "turbo-method": :patch }, class: "bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-8 py-3 rounded-xl font-bold text-lg hover:from-blue-700 hover:to-indigo-700 transition-all duration-300 transform hover:scale-105 shadow-lg" do %>
                      🚀 지원하기
                    <% end %>
                  </div>
                </div>
              <% else %>
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
                  <div class="flex items-center justify-center mb-4">
                    <span class="text-4xl">⏰</span>
                  </div>
                  <h3 class="text-xl font-bold text-gray-800 mb-2">지원이 마감되었습니다</h3>
                  <p class="text-gray-600 mb-4">다른 좋은 기회를 찾아보세요!</p>
                  <%= link_to "다른 구인공고 보기", jobs_path, class: "bg-blue-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-blue-700 transition-colors" %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="border-t border-gray-200 pt-8">
            <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 text-center">
              <h3 class="text-xl font-bold text-orange-800 mb-2">구직자만 지원할 수 있습니다</h3>
              <p class="text-orange-700">구직자 계정으로 로그인해 주세요.</p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="border-t border-gray-200 pt-8">
          <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 text-center">
            <h3 class="text-xl font-bold text-blue-900 mb-2">로그인이 필요합니다</h3>
            <p class="text-blue-700 mb-4">구인공고에 지원하려면 로그인해 주세요.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <%= link_to "로그인", new_user_session_path, class: "bg-blue-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-blue-700 transition-colors" %>
              <%= link_to "회원가입", new_user_registration_path, class: "bg-gray-100 text-blue-700 px-6 py-3 rounded-xl font-medium hover:bg-gray-200 transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>