<% content_for :title, "구인공고 - DentalNow" %>

<div class="min-h-screen">
  <!-- 부드러운 헤더 -->
  <div class="relative overflow-hidden py-16">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-gradient-to-r from-blue-100 to-purple-100 text-blue-800 mb-4">
          💼 구인공고
        </span>
        <h1 class="text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">
            전국 치과에서 전문 의료진을 찾고 있습니다
          </span>
        </h1>
        <p class="text-gray-700 text-lg">🦷 나에게 맞는 완벽한 일자리를 찾아보세요 ✨</p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 검색 및 필터 -->
    <div class="soft-card p-8 mb-10">
      <%= form_with url: jobs_path, method: :get, local: true, class: "space-y-6" do |f| %>
        <!-- 검색 입력 -->
        <div>
          <%= f.text_field :search, 
              placeholder: "병원명, 직종, 지역을 검색하세요",
              value: params[:search],
              class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>
        
        <!-- 필터 옵션들 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">지역</label>
            <%= f.select :location, 
                options_for_select([
                  ["전체", ""],
                  ["서울", "서울"],
                  ["경기", "경기"],
                  ["부산", "부산"],
                  ["대구", "대구"],
                  ["인천", "인천"],
                  ["광주", "광주"],
                  ["대전", "대전"],
                  ["울산", "울산"]
                ], params[:location]),
                {},
                class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">급여</label>
            <%= f.select :salary, 
                options_for_select([
                  ["전체", ""],
                  ["5만원+", "5만원 이상"],
                  ["10만원+", "10만원 이상"],
                  ["15만원+", "15만원 이상"]
                ], params[:salary]),
                {},
                class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">근무형태</label>
            <%= f.select :work_type, 
                options_for_select([
                  ["전체", ""],
                  ["정규직", "정규직"],
                  ["파트타임", "파트타임"],
                  ["대타", "대타"]
                ], params[:work_type]),
                {},
                class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <% if current_user&.jobseeker? && current_user.profile&.address.present? %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">거리</label>
              <%= f.select :distance, 
                  options_for_select([
                    ["전체", ""],
                    ["5km 이내", "5"],
                    ["10km 이내", "10"],
                    ["20km 이내", "20"],
                    ["50km 이내", "50"]
                  ], params[:distance]),
                  {},
                  class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
            </div>
          <% end %>
        </div>
        
        <!-- 검색 버튼 -->
        <div class="flex justify-between items-center">
          <div class="text-gray-600">
            📊 총 <span class="font-bold text-2xl bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"><%= @jobs.count %></span>개의 구인공고
          </div>
          <div class="flex space-x-4">
            <%= link_to "🔄 초기화", jobs_path, class: "soft-btn bg-white/70 text-gray-700 px-6 py-3 font-medium border border-gray-200 hover:bg-white" %>
            <%= f.submit "🔍 검색", class: "soft-btn bg-gradient-to-r from-blue-500 to-purple-600 text-white px-8 py-3 font-semibold transform hover:scale-105" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 구인공고 목록 -->
    <% if @jobs.any? %>
      <div class="grid gap-6">
        <% @jobs.each do |job| %>
          <div class="soft-card p-8 group">
            <div class="flex justify-between items-start mb-6">
              <div class="flex-1">
                <div class="flex items-center space-x-3 mb-3">
                  <span class="soft-tag text-blue-800 text-xs font-medium px-3 py-1.5">
                    ✨ <%= job.status.humanize %>
                  </span>
                  <% if job.is_urgent? %>
                    <span class="bg-gradient-to-r from-red-400 to-pink-500 text-white text-xs font-medium px-3 py-1.5 rounded-full">
                      🔥 긴급
                    </span>
                  <% end %>
                  <span class="text-gray-500 text-sm">📅 <%= time_ago_in_words(job.created_at) %> 전</span>
                </div>
                  
                <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors duration-300">
                  <%= link_to job.title, job_path(job) %>
                </h3>
                
                <div class="flex items-center space-x-6 text-gray-600 mb-4">
                  <div class="flex items-center space-x-2">
                    <span class="text-lg">🏥</span>
                    <span class="font-medium"><%= job.hospital.name %></span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <span class="text-lg">📍</span>
                    <span><%= job.hospital.address&.split(',')&.first || '위치 정보 없음' %></span>
                  </div>
                </div>
                
                <p class="text-gray-700 mb-6 line-clamp-2 leading-relaxed"><%= job.description %></p>
              </div>
              
              <div class="text-right ml-8">
                <div class="bg-gradient-to-br from-blue-500 to-purple-600 text-white p-6 rounded-2xl text-center group-hover:scale-105 transition-transform duration-300">
                  <div class="text-3xl font-bold mb-1">
                    <%= number_to_currency(job.hourly_rate, unit: "", precision: 0) %>원
                  </div>
                  <div class="text-sm opacity-90">
                    ⏰ 시급
                  </div>
                </div>
              </div>
              </div>
              
            <!-- 태그들 -->
            <div class="flex flex-wrap gap-3 mb-6">
              <span class="bg-gradient-to-r from-blue-100 to-purple-100 text-blue-800 text-sm px-4 py-2 rounded-full font-medium">
                📅 <%= job.work_date.strftime('%Y-%m-%d') %>
              </span>
              <span class="bg-gradient-to-r from-green-100 to-emerald-100 text-green-800 text-sm px-4 py-2 rounded-full font-medium">
                ⏰ <%= job.start_time.strftime('%H:%M') %> - <%= job.end_time.strftime('%H:%M') %>
              </span>
              <span class="bg-gradient-to-r from-orange-100 to-yellow-100 text-orange-800 text-sm px-4 py-2 rounded-full font-medium">
                🕐 <%= job.duration_hours %>시간 근무
              </span>
            </div>
            
            <!-- 액션 버튼들 -->
            <div class="flex justify-between items-center">
              <div class="flex space-x-4">
                <%= link_to "📋 자세히 보기", job_path(job), 
                    class: "soft-btn bg-gradient-to-r from-blue-500 to-purple-600 text-white px-6 py-3 font-semibold text-sm transform hover:scale-105" %>
                <% if user_signed_in? %>
                  <%= link_to "💼 지원하기", "#", 
                      class: "soft-btn bg-gradient-to-r from-green-500 to-emerald-600 text-white px-6 py-3 font-semibold text-sm transform hover:scale-105" %>
                <% end %>
              </div>
              
              <% if user_signed_in? %>
                <button class="p-3 text-gray-400 hover:text-red-500 hover:scale-110 transition-all duration-300 rounded-full hover:bg-red-50">
                  <span class="text-xl">💖</span>
                </button>
              <% end %>
            </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 더 많은 공고 보기 -->
      <% if @jobs.count > 10 %>
        <div class="mt-12 text-center">
          <p class="text-gray-600 mb-4">더 많은 구인공고가 있습니다</p>
          <button class="mobile-btn mobile-btn-primary">
            더 보기
          </button>
        </div>
      <% end %>
    <% else %>
      <!-- 빈 상태 -->
      <div class="text-center py-16">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0H8m8 0v6m-8-6v6"/>
          </svg>
        </div>
        <h3 class="text-xl font-medium text-gray-900 mb-2">검색 결과가 없습니다</h3>
        <p class="text-gray-600 mb-6">다른 조건으로 검색해보시거나 키워드를 변경해보세요.</p>
        <%= link_to "전체 구인공고 보기", jobs_path, 
            class: "bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
      </div>
    <% end %>
  </div>
</div>

<!-- CSS 스타일 -->
<style>
  .line-clamp-2 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
</style>
